{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    // "monorepo:aws-sdk-go-v2",
    // "monorepo:aws-sdk-js-v3",
    //"justfalter/renovate-configs"
  ],
  "assignees": [
    "justfalter"
  ],
  "reviewers": [
    "justfalter"
  ],
  "semanticCommitScope": "deps",
  // "automergeType": "pr",
  "prCreation": "immediate",
  "fetchChangeLogs": "pr",
  "ignorePresets": [
    ":ignoreModulesAndTests"
  ],
  "ignorePaths": [
    "**/node_modules/**",
    "**/__fixtures__/**",
    "test/**"
  ],
  "rebaseWhen": "conflicted",
  "baseBranchPatterns": [
    "main"
  ],
  "commitHourlyLimit": 50,
  "prHourlyLimit": 50,
  "prConcurrentLimit": 50,
  "logLevelRemap": [
    {
      "matchMessage": "/statistics/",
      "newLogLevel": "info"
    },
    {
      "matchMessage": "/Fetching changelog/",
      "newLogLevel": "info"
    }
  ],
  // "fetchChangeLogs": "off",
  "packageRules": [
    // {
    //   // Enable specific package changelogs, overriding top-level fetchChangeLogs of off
    //   "matchPackageNames": ["typescript", "github.com/aws/smithy-go"],
    //   "fetchChangeLogs": "pr"
    // },
    {
      // Enable go module updates.
      "matchManagers": [
        "gomod"
      ],
      "enabled": true
    },
    {
      "matchSourceUrls": [
        "https://github.com/aws/aws-sdk-go-v2{/**,}"
      ],
      "fetchChangeLogs": "off",
      "prBodyNotes": [
        "This PR body note came from the rule that disables fetchChangeLogs for aws-sdk-go-v2"
      ]
    },
    {
      "matchSourceUrls": [
        "https://github.com/aws/aws-sdk-js-v3{/**,}"
      ],
      // "fetchChangeLogs": "off",
      "prBodyNotes": [
        "This PR body note came for aws-sdk-js-v3"
      ]
    },
    {
      "matchPackageNames": [
        "github.com/aws/smithy-go{/**,}",
      ],
      "prBodyNotes": [
        "This PR body note is for smithy-go"
      ],
      "fetchChangeLogs": "pr",
    },
    {
      "matchPackageNames": [
        "@aws-sdk/**",
        "github.com/aws/aws-sdk-go-v2{/**,}",
        "github.com/aws/smithy-go{/**,}",
      ],
      "groupName": "aws-sdk-go-v2 stuff"
    }
  ]
}