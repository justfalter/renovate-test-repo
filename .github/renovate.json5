{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "monorepo:aws-sdk-go-v2",
    "monorepo:aws-sdk-js-v3"
  ],
  "assignees": ["justfalter"],
  "reviewers": ["justfalter"],
  "semanticCommitScope": "deps",
  // "automergeType": "pr",
  "prCreation": "immediate",
  "ignorePresets": [":ignoreModulesAndTests"],
  "ignorePaths": ["**/node_modules/**", "**/__fixtures__/**", "test/**"],
  "rebaseWhen": "conflicted",
  "baseBranchPatterns": ["$default"],
  "commitHourlyLimit": 10,
  "prHourlyLimit": 10,
  "prConcurrentLimit": 10,
  "logLevelRemap": [
    {
      "matchMessage": "/statistics/",
      "newLogLevel": "info"
    },
    {
      "matchMessage": "/Fetching changelog/",
      "newLogLevel": "info"
    }
  ],
  "packageRules": [
    {
      // Enable go module updates.
      "matchManagers": ["gomod"],
      "enabled": true
    },
    {
      "matchSourceUrls": ["https://github.com/aws/aws-sdk-js-v3{/**,}"],
      "groupName": "aws-sdk-js-v3 monorepo",
      "disableChangeLog": true
    },
    {
      "matchSourceUrls": ["https://github.com/aws/aws-sdk-go-v2{/**,}"],
      "groupName": "aws-sdk-go-v2 monorepo",
      "disableChangeLog": true
    }
  ]
}